{
  "release-type": "rust",
  "include-component-in-tag": false,

  "separate-pull-requests": false,

  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "refactor", "section": "Refactoring" },
    { "type": "docs", "section": "Documentation" },
    { "type": "chore", "section": "Chores" }
  ],

  "packages": {
    "crates/icb-common": {
      "component": "icb-common",
      "changelog-path": "crates/icb-common/CHANGELOG.md"
    },
    "crates/icb-parser": {
      "component": "icb-parser",
      "changelog-path": "crates/icb-parser/CHANGELOG.md"
    },
    "crates/icb-graph": {
      "component": "icb-graph",
      "changelog-path": "crates/icb-graph/CHANGELOG.md"
    },
    "crates/icb-clang": {
      "component": "icb-clang",
      "changelog-path": "crates/icb-clang/CHANGELOG.md"
    },
    "crates/icb-server": {
      "component": "icb-server",
      "changelog-path": "crates/icb-server/CHANGELOG.md"
    },
    "crates/icb-report": {
      "component": "icb-report",
      "changelog-path": "crates/icb-report/CHANGELOG.md"
    },
    "crates/icb-cli": {
      "component": "icb-cli",
      "changelog-path": "crates/icb-cli/CHANGELOG.md"
    }
  }
}